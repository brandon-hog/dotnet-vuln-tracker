@page "/"
@using Client.Providers
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>VulnTracker - Centralized Vulnerability Management</PageTitle>

@* --- Navbar Section --- *@
<header class="sticky-top">
    <nav class="navbar navbar-expand-lg navbar-dark bg-black">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">VulnTracker</a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="#">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#features">Features</a>
                    </li>
                </ul>
            </div>
        </div>
        <div class="pe-5">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" href="/register">Register</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/login">Login</a>
                </li>
            </ul>
        </div>
    </nav>
</header>

@* --- Hero Section --- *@
<div class="px-4 py-5 mb-5 text-center bg-dark text-white shadow">
    <img class="d-block mx-auto mb-4" src="icon.svg" alt="VulnTracker Logo" width="200" height="200">
    <h1 class="display-5 fw-bold text-light">Centralize Your Security Posture</h1>
    <div class="col-lg-6 mx-auto">
        <p class="lead mb-4 text-white-50">
            Automatically track assets, correlate software versions with the National Vulnerability Database (NVD), and prioritize critical CVEs. VulnTracker gives you the visibility needed to remediate faster.
        </p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <AuthorizeView>
                <Authorized>
                    @* If logged in, send them straight to the data *@
                    <a href="/assets" class="btn btn-primary btn-lg px-4 gap-3">View Network Assets</a>
                </Authorized>
                <NotAuthorized>
                    @* If not logged in, show primary CTAs *@
                    <a href="/register" class="btn btn-primary btn-lg px-4 gap-3">Get Started</a>
                    <a href="#features" class="btn btn-outline-light btn-lg px-4">Explore Features</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>

@* --- Features Section (Traditional Grid) --- *@
<div class="container px-4 py-5" id="features">
    <h2 class="pb-2 border-bottom fw-bold text-center mb-5">Built for Security Teams</h2>
    <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
        
        @* Feature 1 *@
        <div class="col d-flex align-items-start">
            <div class="icon-square bg-light text-primary flex-shrink-0 me-3 rounded-circle p-3 shadow-sm">
                <i class="bi bi-hdd-network-fill fs-4"></i> @* Assuming Bootstrap Icons are enabled *@
            </div>
            <div>
                <h3 class="fs-4 fw-bold">Dynamic Asset Inventory</h3>
                <p class="text-muted">Maintain a real-time, authenticated inventory of your hostnames and IP addresses across your infrastructure.</p>
            </div>
        </div>

        @* Feature 2 *@
        <div class="col d-flex align-items-start">
            <div class="icon-square bg-light text-primary flex-shrink-0 me-3 rounded-circle p-3 shadow-sm">
                <i class="bi bi-shield-check-fill fs-4"></i>
            </div>
            <div>
                <h3 class="fs-4 fw-bold">Automated CVE Correlation</h3>
                <p class="text-muted">API integration with the National Vulnerability Database automatically scans your assets against latest vulnerability releases.</p>
            </div>
        </div>

        @* Feature 3 *@
        <div class="col d-flex align-items-start">
            <div class="icon-square bg-light text-primary flex-shrink-0 me-3 rounded-circle p-3 shadow-sm">
                <i class="bi bi-bar-chart-steps fs-4"></i>
            </div>
            <div>
                <h3 class="fs-4 fw-bold">Criticality Scoring</h3>
                <p class="text-muted">View full CVSS scores and severities instantly. Prioritize high-risk vulnerabilities that matter most to your business.</p>
            </div>
        </div>
    </div>
</div>

@* Minimal footer for a professional portfolio look *@
<footer class="pt-5 mt-5 text-muted border-top text-center">
    Built with .NET 10, PostgreSQL, and Bootstrap | VulnTracker Portfolio Demo
</footer>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }
}