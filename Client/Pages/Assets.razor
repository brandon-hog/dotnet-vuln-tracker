@page "/assets"
@using Client.Layout
@using Microsoft.AspNetCore.Authorization
@using Shared.Dtos
@attribute [Authorize]
@layout MainLayout
@inject HttpClient APIClient

<div class="container-fluid h-100 d-flex flex-column">

    @* Header / Search area *@
    <div class="d-flex justify-content-between">
        <h3>Assets</h3>

        <div class="d-flex gap-2">
            <div class="d-flex input-group w-auto">
                <input class="form-control w-auto" type="search" placeholder="Search..." @bind=searchQuery />
                <button @onclick="HandleSubmit" class="btn btn-submit bg-dark text-white">Submit</button>
            </div>
            @* Create Asset button *@
            <a href="/assets/create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Add Asset
            </a>
        </div>
    </div>

    <hr />

    @* Body / Resulting assets *@
    <div class="table-responsive my-4 flex-grow-1 shadow-sm rounded">
        <table class="table table-hover table-striped align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th scope="col" style="width: 25%">Hostname</th>
                    <th scope="col" style="width: 20%">IP Address</th>
                    <th scope="col" style="width: 30%">Vulnerability Status</th>
                    <th scope="col" style="width: 25%" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @if (loading)
                {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                        </td>
                    </tr>
                }
                else if (assets?.Data != null && assets.Data.Any())
                {
                    @foreach (var asset in assets.Data)
                    {
                        <tr>
                            <td class="fw-semibold" title="ID: @asset.Id">@asset.Hostname</td>
                            <td class="text-muted">@asset.IpAddress</td>
                            <td>
                                @if (asset.Vulnerabilities != null && asset.Vulnerabilities.Any())
                                {
                                    <span class="badge bg-danger rounded-pill shadow-sm">
                                        @asset.Vulnerabilities.Count() CVEs
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success rounded-pill shadow-sm">Secure</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-2">
                                    <a href="/assets/@asset.Id" class="btn btn-sm btn-outline-dark">View Details</a>
                                    <a href="/assets/edit/@asset.Id" class="btn btn-sm btn-outline-secondary" title="Edit Asset">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                            <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                                            <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
                                        </svg>
                                    </a>
                                    <button
                                        type="button"
                                        class="btn btn-sm btn-danger"
                                        disabled="@(loading || deletingAssetIds.Contains(asset.Id))"
                                        @onclick="() => DeleteAsset(asset.Id)">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash-fill" viewBox="0 0 16 16">
                                            <path d="M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5M8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5m3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0"/>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else if (assets != null)
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            No assets found matching your search criteria.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Page information *@
    <div class="d-flex mt-auto justify-content-center">
        <nav>
            <ul class="pagination">
                <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                    <a class="page-link" disabled=@(pageNumber <= 1) @onclick=decrementPage>
                        Previous
                    </a>
                </li>
                <li class="page-item">
                    <a class="page-link">
                        @pageNumber of @totalPages
                    </a>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                    <a class="page-link" disabled=@(pageNumber >= totalPages) @onclick=incrementPage>
                        Next
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

@code {
    private bool loading = false;
    private string? error;
    private String searchQuery = String.Empty;
    private int pageSize = 10;
    private int pageNumber = 1;
    private int totalPages = 0;
    private PagedResponse<AssetDto>? assets;
    private HashSet<Guid> deletingAssetIds = [];

    /// <summary>
    /// On first load, fetches the first ten assets
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await HandleSubmit();
    }

    private async Task decrementPage() {
        if (pageNumber > 1) {
            pageNumber--;
            await HandleSubmit();
        }
    }

    private async Task incrementPage() {
        if (pageNumber < totalPages) {
            pageNumber++;
            await HandleSubmit();
        }
    }

    private async Task HandleSubmit() {
        try
        {
            loading = true;

            // Get the assets from the paginated endpoint
            assets = await APIClient.GetFromJsonAsync<PagedResponse<AssetDto>>(
                $"assets?pageSize={pageSize}&pageNumber={pageNumber}&searchQuery={Uri.EscapeDataString(searchQuery)}"
            );

            int totalRecords = assets?.TotalRecords ?? 0;
            totalPages = pageSize > 0 ? (totalRecords + pageSize - 1) / pageSize : 0;
        }
        catch (HttpRequestException e)
        {
            error = e.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task DeleteAsset(Guid assetId)
    {
        if (deletingAssetIds.Contains(assetId))
        {
            return;
        }

        deletingAssetIds.Add(assetId);

        try
        {
            await APIClient.DeleteAsync($"assets/{assetId}");
            await HandleSubmit();
        }
        catch (HttpRequestException e)
        {
            error = e.Message;
        }
        finally
        {
            deletingAssetIds.Remove(assetId);
        }
    }
}